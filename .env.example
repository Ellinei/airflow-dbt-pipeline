# Copy this file to .env and fill in real values. .env is gitignored — never
# commit it. See README.md for the full setup walkthrough.

# ── Airflow metadata database ──────────────────────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow

# ── Data warehouse database ────────────────────────────────────────────────────
WAREHOUSE_DB_USER=warehouse
WAREHOUSE_DB_PASSWORD=changeme
WAREHOUSE_DB_NAME=warehouse

# ── Airflow UID (keeps file ownership consistent on Linux/Mac; ignored on Win) ─
AIRFLOW_UID=50000

# ── Alerting ───────────────────────────────────────────────────────────────────
# Paste a Slack Incoming Webhook URL to enable failure alerts.  Leave blank to
# disable silently (the callback checks for an empty string before posting).
SLACK_WEBHOOK_URL=

# ── Cognitive layer ──────────────────────────────────────────────────────────
# OpenAI key enables semantic search + answer generation in the RAG agent.
# Leave blank to skip embedding generation (pgvector table is still created).
OPENAI_API_KEY=

# ── Airflow encryption / auth ───────────────────────────────────────────────────
# Fernet key encrypts Connection passwords in the Airflow metadata DB.
# Generate one with:
#   python -c "import base64, secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
AIRFLOW_FERNET_KEY=changeme
# Password for the Airflow UI admin user created by airflow-init (username: admin).
AIRFLOW_ADMIN_PASSWORD=changeme

# ── OpenMetadata (--profile catalog) ────────────────────────────────────────────
OPENMETADATA_MYSQL_ROOT_PASSWORD=changeme
OPENMETADATA_DB_PASSWORD=changeme
# OpenMetadata's public demo/quickstart bot token (documented default, not unique
# to this repo). Fine for local dev; generate your own via Settings -> Bots if
# this ever runs beyond localhost.
