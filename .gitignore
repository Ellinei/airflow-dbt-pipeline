# ── Credentials — NEVER commit these ──────────────────────────────────────────
.env

# ── Airflow runtime artefacts ─────────────────────────────────────────────────
logs/
plugins/

# ── dbt compiled / generated files ───────────────────────────────────────────
dbt_project/target/
dbt_project/dbt_packages/
dbt_project/.user.yml
dbt_project/logs/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── IDE / tooling ─────────────────────────────────────────────────────────────
.claude/
.mcp.json
.vscode/
.idea/

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Local-only large datasets (never commit) ──────────────────────────────────
data/olist/*.csv

# ── OpenMetadata ingestion configs generated from *.yaml.template (contain
#    credentials interpolated from .env) — templates themselves stay tracked ──
openmetadata/*.yaml
!openmetadata/*.yaml.template
